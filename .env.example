# Required: auth key for LiteLLM proxy (use any secure string)
LITELLM_MASTER_KEY=sk-ada-dev-key

# Model routing (provider/model id, e.g. openai/gpt-4o-mini)
LITE_MODEL=
TOOL_CREATOR_MODEL=

# Reasoning/thinking for the lite chat model (low, medium, high; empty to disable)
LITE_MODEL_REASONING_EFFORT=low

# Legacy fallbacks (optional; used if LITE_MODEL / TOOL_CREATOR_MODEL are unset)
CHAT_MODEL=
SECOND_MODEL=

# Add keys for the providers you want to use.
# Only providers with valid keys will return models in the picker.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ElevenLabs (optional — for read-aloud voice output; can also be set in Settings)
ELEVENLABS_API_KEY=

# Debug logging (see logs/chat.log when using .\start.ps1)
# ADA_LOG_LEVEL=DEBUG   # log every stream delta
# ADA_LOG_MAX_BODY=32000

# Native defaults (set automatically by start.ps1; override if needed)
# LITELLM_URL=http://127.0.0.1:4000
# TOOL_RUNTIME_URL=http://127.0.0.1:8090
